# Usamos una imagen ligera de Python 3.12 como base para reducir el tamaño del contenedor
FROM python:3.12-slim

# Establecemos el directorio de trabajo dentro del contenedor a /app
# CAMBIO: Anteriormente era /API, pero docker-compose.yml montaba los archivos en /app. 
# Ahora coinciden, evitando problemas de rutas o archivos no encontrados.
WORKDIR /app

# Copiamos solo el archivo de requerimientos primero para aprovechar la caché de Docker
# Si solo cambia el código pero no los requerimientos, Docker omitirá este paso en futuras construcciones
COPY requirements.txt .

# Instalamos las dependencias sin guardar la caché de pip (--no-cache-dir) para que la imagen final sea más liviana
RUN pip install --no-cache-dir -r requirements.txt

# Copiamos el resto del código de la aplicación al contenedor
COPY . . 

# Documentamos que la aplicación usará el puerto 5000
EXPOSE 5000

# Iniciamos el servidor con uvicorn en el puerto 5000, permitiendo conexiones desde cualquier IP (0.0.0.0)
# La opción --reload permite que los cambios en el código se reflejen automáticamente (ideal para desarrollo junto con volumes)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "5000", "--reload"]